# Firebase Web Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (Server-side)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# LLM APIs (at least one required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Search API
TAVILY_API_KEY=

# Voice Provider API Keys for Multilingual AI
# ElevenLabs (Primary provider for best quality multilingual voice)
ELEVENLABS_API_KEY=
# MiniMax (Advanced emotional voice synthesis)
MINIMAX_API_KEY=

# AI Mode (firestore = skip WordPress, use Firestore CMS only)
AI_MODE=firestore

# WordPress (Optional - only used if AI_MODE != firestore)
# WORDPRESS_BASE_URL=https://blog.kraftmortgages.ca
# WORDPRESS_USERNAME=admin
# WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Google Search Console (Optional)
# GSC_CLIENT_EMAIL=service-account@your-project.iam.gserviceaccount.com
# GSC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GSC_SITE_URL=https://www.kraftmortgages.ca

# Cron Security
CREWAI_SECRET=change-me-to-random-string
# --- Added in Phase 1 (env vars the app actually uses) ---
# Site URL (canonical URLs, sitemap, schema). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.kraftmortgages.ca

# HubSpot CRM (lead/contact sync)
HUBSPOT_ACCESS_TOKEN=
HUBSPOT_API_KEY=

# Meta / Facebook (Pixel + Conversions API + Page webhooks)
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_ACCESS_TOKEN=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# Thinkr voice agent
THINKR_API_KEY=
THINKR_AGENT_ID=
THINKR_CALLER_PHONE=
THINKR_OUTBOUND_SCENARIO_ID=
THINKR_WEBHOOK_SECRET=

# Voice agent widget (SalesCloser / embedded)
NEXT_PUBLIC_VOICE_AGENT_DOMAIN=
NEXT_PUBLIC_VOICE_AGENT_SCRIPT_URL=
NEXT_PUBLIC_VOICE_AGENT_WIDGET_ID=

# Twilio (SMS verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_CALLER_ID=

# Brevo (transactional email) + Discord lead notifications
BREVO_API_KEY=
DISCORD_LEAD_WEBHOOK_URL=

# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SEGMENT_WRITE_KEY=

# PWA
NEXT_PUBLIC_PWA_ENABLED=true
