{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "all" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://www.kraftmortgages.ca/$1",
      "permanent": true,
      "has": [{ "type": "host", "value": "kraftmortgages.ca" }]
    }
  ],
  "rewrites": [
    { 
      "source": "/crewapi/(.*)", 
      "destination": "https://kraft-crewapi.vercel.app/$1"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "5 9 * * *"
    }
  ]
}